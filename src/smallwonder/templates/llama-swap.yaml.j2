# Generated by smallwonder — llama-swap config (fully-OSS backend).
# Models JIT-load on first request and unload after ttl seconds.

listen: "127.0.0.1:{{ ports.backend }}"

macros:
  llama: "{{ llama_server_bin }} --port ${PORT} -ngl 999 --ctx-size {{ context_tokens }}"

models:
{% for role, ref in models.items() if role != "embed" %}
  "{{ ref }}":
    cmd: |
      ${llama} -hf {{ ref }}
    ttl: {{ 7200 if role == "fast" else 900 }}
{% endfor %}
  "{{ models['embed'] }}":
    cmd: |
      {{ llama_server_bin }} --port ${PORT} -hf {{ models["embed"] }} --embedding --pooling mean
    ttl: 86400

# Generated by smallwonder — edit ~/.smallwonder/config.yaml and run
# `smallwonder up` to regenerate. Manual edits here will be overwritten.

model_list:
  # --- Role aliases (the stable public API) ---------------------------------
{% for role in ["coder", "general", "fast"] %}
  - model_name: {{ role }}
    litellm_params:
      model: openai/{{ models[role] }}
      api_base: {{ backend_base }}/v1
      api_key: local-backend
      allowed_openai_params: ["reasoning_effort"]   # "none" disables thinking per-request
      extra_body:
        ttl: {{ 7200 if role == "fast" else 900 }}
{% endfor %}
  - model_name: local-embed
    litellm_params:
      model: openai/{{ models["embed"] }}
      api_base: {{ backend_base }}/v1
      api_key: local-backend

  # --- Auto-router: "auto" picks a role per query ---------------------------
  - model_name: auto
    litellm_params:
      model: auto_router/main
      auto_router_config_path: {{ render_dir }}/auto_router.json
      auto_router_default_model: general
      auto_router_embedding_model: local-embed
{% if image_enabled %}

  - model_name: image                       # image generation (Draw Things via shim)
    litellm_params:
      model: openai/draw-things
      api_base: http://127.0.0.1:{{ ports.image_shim }}/v1
      api_key: none
{% endif %}

  # --- Passthrough: any model on the backend, by id, zero config ------------
  - model_name: "local/*"
    litellm_params:
      model: "openai/*"
      api_base: {{ backend_base }}/v1
      api_key: local-backend
      allowed_openai_params: ["reasoning_effort"]

litellm_settings:
  telemetry: false
  drop_params: true

general_settings:
  master_key: {{ api_key }}
